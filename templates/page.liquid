<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 24px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #18181b;
  }

  .page-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .page-title {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0;
  }

  .page-content {
    font-size: 16px;
    line-height: 1.8;
    color: #3f3f46;
  }

  /* Rich Text Editor Styling Defaults */
  .page-content p {
    margin: 0 0 24px 0;
  }

  .page-content p:last-child {
    margin-bottom: 0;
  }

  .page-content h2 {
    font-size: 24px;
    font-weight: 600;
    margin: 40px 0 16px 0;
    color: #18181b;
    letter-spacing: -0.01em;
  }

  .page-content h3 {
    font-size: 20px;
    font-weight: 600;
    margin: 32px 0 12px 0;
    color: #18181b;
  }

  .page-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 24px 0;
  }

  .page-content blockquote {
    border-left: 4px solid #18181b;
    margin: 32px 0;
    padding: 8px 0 8px 24px;
    font-style: italic;
    color: #71717a;
    background-color: #f4f4f5;
    border-radius: 0 8px 8px 0;
  }

  .page-content ul,
  .page-content ol {
    margin: 0 0 24px 0;
    padding-left: 24px;
  }

  .page-content li {
    margin-bottom: 8px;
  }

  .page-content a {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .page-content a:hover {
    color: #1d4ed8;
  }

  @media screen and (max-width: 768px) {
    .page-container {
      padding: 50px 20px;
    }
    .page-title {
      font-size: 32px;
    }
    .page-content {
      font-size: 15px;
      line-height: 1.7;
    }
  }
</style>

<article class="page-container">
  <header class="page-header">
    <h1 class="page-title">{{ page.title }}</h1>
  </header>
  
  <div class="page-content rte">
    {{ page.content }}
  </div>
</article>
