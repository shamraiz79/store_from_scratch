{% style %}
  #Hero-{{ section.id }} {
    position: relative;
    overflow: hidden;
    display: flex;
    width: 100%;
    background-color: {{ section.settings.bg_color }};
  }

  /* Height Settings */
  #Hero-{{ section.id }}.custom-hero-height--small {
    min-height: {{ section.settings.height_small_mobile }}px;
  }
  #Hero-{{ section.id }}.custom-hero-height--medium {
    min-height: {{ section.settings.height_medium_mobile }}px;
  }
  #Hero-{{ section.id }}.custom-hero-height--large {
    min-height: {{ section.settings.height_large_mobile }}px;
  }
  #Hero-{{ section.id }}.custom-hero-height--full-screen {
    min-height: 100vh;
    min-height: 100dvh;
  }
  #Hero-{{ section.id }}.custom-hero-height--adapt {
    min-height: 350px;
  }

  @media screen and (min-width: 768px) {
    #Hero-{{ section.id }}.custom-hero-height--small {
      min-height: {{ section.settings.height_small_desktop }}px;
    }
    #Hero-{{ section.id }}.custom-hero-height--medium {
      min-height: {{ section.settings.height_medium_desktop }}px;
    }
    #Hero-{{ section.id }}.custom-hero-height--large {
      min-height: {{ section.settings.height_large_desktop }}px;
    }
    #Hero-{{ section.id }}.custom-hero-height--full-screen {
      min-height: 100vh;
      min-height: 100dvh;
    }
    {%- if section.settings.hero_height == 'adapt' and section.settings.image != blank -%}
      #Hero-{{ section.id }}.custom-hero-height--adapt {
        min-height: 0;
        aspect-ratio: {{ section.settings.image.aspect_ratio }};
      }
    {%- endif -%}
  }

  /* Background Media */
  #Hero-{{ section.id }} .custom-hero-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  #Hero-{{ section.id }} .custom-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  {%- if section.settings.hover_zoom -%}
    #Hero-{{ section.id }}:hover .custom-hero-image {
      transform: scale(1.05);
    }
  {%- endif -%}

  #Hero-{{ section.id }} .custom-hero-image--desktop {
    display: block;
  }
  #Hero-{{ section.id }} .custom-hero-image--mobile {
    display: none;
  }

  @media screen and (max-width: 767px) {
    {%- if section.settings.mobile_image != blank -%}
      #Hero-{{ section.id }} .custom-hero-image--desktop {
        display: none;
      }
      #Hero-{{ section.id }} .custom-hero-image--mobile {
        display: block;
      }
      {%- if section.settings.hero_height == 'adapt' -%}
        #Hero-{{ section.id }}.custom-hero-height--adapt {
          min-height: 0;
          aspect-ratio: {{ section.settings.mobile_image.aspect_ratio }};
        }
      {%- endif -%}
    {%- endif -%}
  }

  #Hero-{{ section.id }} .custom-hero-placeholder {
    background-color: #f3f4f6;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #Hero-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: rgba(0,0,0,0.08);
  }

  /* Overlay */
  #Hero-{{ section.id }} .custom-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    background-color: {{ section.settings.overlay_color }};
    {%- if section.settings.overlay_gradient != blank -%}
      background: {{ section.settings.overlay_gradient }};
    {%- endif -%}
  }

  /* Container */
  #Hero-{{ section.id }} .custom-hero-container {
    position: relative;
    z-index: 3;
    width: 100%;
    padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_right_mobile }}px {{ section.settings.padding_bottom_mobile }}px {{ section.settings.padding_left_mobile }}px;
    display: flex;
    box-sizing: border-box;
  }

  @media screen and (min-width: 768px) {
    #Hero-{{ section.id }} .custom-hero-container {
      padding: {{ section.settings.padding_top_desktop }}px {{ section.settings.padding_right_desktop }}px {{ section.settings.padding_bottom_desktop }}px {{ section.settings.padding_left_desktop }}px;
      max-width: {{ section.settings.container_max_width }}px;
      margin: 0 auto;
    }
  }

  #Hero-{{ section.id }} .custom-hero-content-wrapper {
    display: flex;
    width: 100%;
    height: 100%;
    
    /* Desktop Position Mapping */
    {%- case section.settings.content_position -%}
      {%- when 'top-left' -%}
        align-items: flex-start;
        justify-content: flex-start;
      {%- when 'top-center' -%}
        align-items: flex-start;
        justify-content: center;
      {%- when 'top-right' -%}
        align-items: flex-start;
        justify-content: flex-end;
      {%- when 'middle-left' -%}
        align-items: center;
        justify-content: flex-start;
      {%- when 'middle-center' -%}
        align-items: center;
        justify-content: center;
      {%- when 'middle-right' -%}
        align-items: center;
        justify-content: flex-end;
      {%- when 'bottom-left' -%}
        align-items: flex-end;
        justify-content: flex-start;
      {%- when 'bottom-center' -%}
        align-items: flex-end;
        justify-content: center;
      {%- when 'bottom-right' -%}
        align-items: flex-end;
        justify-content: flex-end;
    {%- endcase -%}
  }

  @media screen and (max-width: 767px) {
    #Hero-{{ section.id }} .custom-hero-content-wrapper {
      /* Mobile Position Mapping */
      {%- case section.settings.content_position_mobile -%}
        {%- when 'top' -%}
          align-items: flex-start;
        {%- when 'middle' -%}
          align-items: center;
        {%- when 'bottom' -%}
          align-items: flex-end;
      {%- endcase -%}
      
      {%- case section.settings.text_alignment_mobile -%}
        {%- when 'left' -%}
          justify-content: flex-start;
        {%- when 'center' -%}
          justify-content: center;
        {%- when 'right' -%}
          justify-content: flex-end;
      {%- endcase -%}
    }
  }

  #Hero-{{ section.id }} .custom-hero-content {
    max-width: {{ section.settings.content_max_width }}px;
    width: 100%;
    text-align: {{ section.settings.text_alignment }};
    display: flex;
    flex-direction: column;
  }

  @media screen and (max-width: 767px) {
    #Hero-{{ section.id }} .custom-hero-content {
      text-align: {{ section.settings.text_alignment_mobile }};
      align-items: {% if section.settings.text_alignment_mobile == 'center' %}center{% elsif section.settings.text_alignment_mobile == 'right' %}flex-end{% else %}flex-start{% endif %};
    }
  }

  @media screen and (min-width: 768px) {
    #Hero-{{ section.id }} .custom-hero-content {
      align-items: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    }
  }

  /* Badge Styling */
  #Hero-{{ section.id }} .custom-hero-badge {
    display: inline-block;
    font-size: {{ section.settings.badge_size_mobile }}px;
    font-weight: {{ section.settings.badge_weight }};
    color: {{ section.settings.badge_text_color }};
    background-color: {{ section.settings.badge_bg_color }};
    padding: {{ section.settings.badge_padding_y }}px {{ section.settings.badge_padding_x }}px;
    border-radius: {{ section.settings.badge_border_radius }}px;
    text-transform: {% if section.settings.badge_uppercase %}uppercase{% else %}none{% endif %};
    letter-spacing: {{ section.settings.badge_letter_spacing }}px;
    margin-bottom: {{ section.settings.badge_margin_bottom }}px;
    line-height: 1.2;
    max-width: max-content;
  }

  @media screen and (min-width: 768px) {
    #Hero-{{ section.id }} .custom-hero-badge {
      font-size: {{ section.settings.badge_size_desktop }}px;
    }
  }

  /* Heading Styling */
  #Hero-{{ section.id }} .custom-hero-heading {
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px 0;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: {{ section.settings.heading_line_height }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    text-transform: {% if section.settings.heading_uppercase %}uppercase{% else %}none{% endif %};
  }

  @media screen and (min-width: 768px) {
    #Hero-{{ section.id }} .custom-hero-heading {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
  }

  /* Description Styling */
  #Hero-{{ section.id }} .custom-hero-description {
    margin: 0 0 {{ section.settings.description_margin_bottom }}px 0;
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size_mobile }}px;
    font-weight: {{ section.settings.description_weight }};
    line-height: {{ section.settings.description_line_height }};
  }

  #Hero-{{ section.id }} .custom-hero-description p {
    margin: 0 0 10px 0;
    color: inherit;
    font-size: inherit;
    line-height: inherit;
  }
  #Hero-{{ section.id }} .custom-hero-description p:last-child {
    margin: 0;
  }

  @media screen and (min-width: 768px) {
    #Hero-{{ section.id }} .custom-hero-description {
      font-size: {{ section.settings.description_size_desktop }}px;
    }
  }

  /* Buttons Wrapper */
  #Hero-{{ section.id }} .custom-hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: {{ section.settings.button_gap }}px;
    justify-content: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    width: 100%;
  }

  @media screen and (max-width: 767px) {
    #Hero-{{ section.id }} .custom-hero-buttons {
      justify-content: {% if section.settings.text_alignment_mobile == 'center' %}center{% elsif section.settings.text_alignment_mobile == 'right' %}flex-end{% else %}flex-start{% endif %};
      {% if section.settings.buttons_stack_mobile %}
        flex-direction: column;
        width: 100%;
      {% endif %}
    }
  }

  /* Common Button Styles */
  #Hero-{{ section.id }} .custom-hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    letter-spacing: 0.5px;
    cursor: pointer;
    box-sizing: border-box;
    {% if section.settings.buttons_stack_mobile %}
      width: 100%;
    {% endif %}
  }

  @media screen and (min-width: 768px) {
    #Hero-{{ section.id }} .custom-hero-btn {
      width: auto;
    }
  }

  /* Primary Button Specifics */
  #Hero-{{ section.id }} .custom-hero-btn--primary {
    background-color: {{ section.settings.btn_1_bg }};
    color: {{ section.settings.btn_1_text }};
    font-size: {{ section.settings.btn_1_size }}px;
    padding: {{ section.settings.btn_1_padding_y }}px {{ section.settings.btn_1_padding_x }}px;
    border: {{ section.settings.btn_1_border_width }}px solid {{ section.settings.btn_1_border_color }};
    border-radius: {{ section.settings.btn_1_border_radius }}px;
    text-transform: {% if section.settings.btn_1_uppercase %}uppercase{% else %}none{% endif %};
  }

  #Hero-{{ section.id }} .custom-hero-btn--primary:hover {
    background-color: {{ section.settings.btn_1_bg_hover }};
    color: {{ section.settings.btn_1_text_hover }};
    border-color: {{ section.settings.btn_1_border_hover }};
    {%- if section.settings.btn_1_scale -%}
      transform: scale(1.05);
    {%- endif -%}
  }

  /* Secondary Button Specifics */
  #Hero-{{ section.id }} .custom-hero-btn--secondary {
    background-color: {{ section.settings.btn_2_bg }};
    color: {{ section.settings.btn_2_text }};
    font-size: {{ section.settings.btn_2_size }}px;
    padding: {{ section.settings.btn_2_padding_y }}px {{ section.settings.btn_2_padding_x }}px;
    border: {{ section.settings.btn_2_border_width }}px solid {{ section.settings.btn_2_border_color }};
    border-radius: {{ section.settings.btn_2_border_radius }}px;
    text-transform: {% if section.settings.btn_2_uppercase %}uppercase{% else %}none{% endif %};
  }

  #Hero-{{ section.id }} .custom-hero-btn--secondary:hover {
    background-color: {{ section.settings.btn_2_bg_hover }};
    color: {{ section.settings.btn_2_text_hover }};
    border-color: {{ section.settings.btn_2_border_hover }};
    {%- if section.settings.btn_2_scale -%}
      transform: scale(1.05);
    {%- endif -%}
  }

  /* Entrance Animations */
  .custom-hero-animate--fade-in {
    opacity: 0;
    animation: heroFadeIn 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  .custom-hero-animate--slide-up > * {
    opacity: 0;
    transform: translateY(30px);
    animation: heroSlideUp 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  .custom-hero-animate--slide-up > *:nth-child(1) { animation-delay: 0.1s; }
  .custom-hero-animate--slide-up > *:nth-child(2) { animation-delay: 0.25s; }
  .custom-hero-animate--slide-up > *:nth-child(3) { animation-delay: 0.4s; }
  .custom-hero-animate--slide-up > *:nth-child(4) { animation-delay: 0.55s; }

  .custom-hero-animate--zoom-in {
    opacity: 0;
    transform: scale(0.95);
    animation: heroZoomIn 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
    }
  }

  @keyframes heroSlideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroZoomIn {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
{% endstyle %}

<div id="Hero-{{ section.id }}" class="custom-hero-section custom-hero-height--{{ section.settings.hero_height }}">
  {%- if section.settings.image != blank -%}
    <div class="custom-hero-media">
      {%- liquid
        assign image = section.settings.image
        assign mobile_image = section.settings.mobile_image | default: image
        assign focal_point = image.presentation.focal_point
        assign mobile_focal_point = mobile_image.presentation.focal_point
      -%}
      
      {%- comment -%} Desktop Image {%- endcomment -%}
      {{ image | image_url: width: 3840 | image_tag:
        loading: 'eager',
        class: 'custom-hero-image custom-hero-image--desktop',
        sizes: '100vw',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
        style: 'object-position: focal_point;' | replace: 'focal_point', focal_point
      }}

      {%- comment -%} Mobile Image {%- endcomment -%}
      {%- if section.settings.mobile_image != blank -%}
        {{ mobile_image | image_url: width: 1500 | image_tag:
          loading: 'eager',
          class: 'custom-hero-image custom-hero-image--mobile',
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500',
          style: 'object-position: focal_point;' | replace: 'focal_point', mobile_focal_point
        }}
      {%- endif -%}
    </div>
  {%- else -%}
    {%- comment -%} Fallback placeholder or color {%- endcomment -%}
    <div class="custom-hero-media custom-hero-placeholder">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  {%- endif -%}

  {%- comment -%} Overlay {%- endcomment -%}
  <div class="custom-hero-overlay"></div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="custom-hero-container">
    <div class="custom-hero-content-wrapper">
      <div class="custom-hero-content custom-hero-animate--{{ section.settings.animation }}">
        {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
          <span class="custom-hero-badge">{{ section.settings.badge_text }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="custom-hero-heading">
            {{ section.settings.heading | escape }}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="custom-hero-description">
            {{ section.settings.description }}
          </div>
        {%- endif -%}

        {%- if section.settings.button_1_label != blank or section.settings.button_2_label != blank -%}
          <div class="custom-hero-buttons">
            {%- if section.settings.button_1_label != blank -%}
              <a href="{{ section.settings.button_1_link | default: '#' }}" class="custom-hero-btn custom-hero-btn--primary">
                {{ section.settings.button_1_label | escape }}
              </a>
            {%- endif -%}
            {%- if section.settings.button_2_label != blank -%}
              <a href="{{ section.settings.button_2_link | default: '#' }}" class="custom-hero-btn custom-hero-btn--secondary">
                {{ section.settings.button_2_label | escape }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Hero Section",
  "tag": "section",
  "class": "custom-hero-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Background Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Background Image",
      "info": "Optional. Falls back to desktop image if blank."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f3f4f6",
      "info": "Visible while image loads or if no image is selected."
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "color_background",
      "id": "overlay_gradient",
      "label": "Overlay Gradient",
      "info": "If set, overrides solid overlay color."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "hover_zoom",
      "label": "Zoom background image on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout & Dimensions"
    },
    {
      "type": "select",
      "id": "hero_height",
      "label": "Hero Height Style",
      "options": [
        { "value": "adapt", "label": "Adapt to Image Aspect Ratio" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full-screen", "label": "Full Screen" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "height_small_desktop",
      "min": 300,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Desktop Height - Small Style",
      "default": 450
    },
    {
      "type": "range",
      "id": "height_medium_desktop",
      "min": 400,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Desktop Height - Medium Style",
      "default": 600
    },
    {
      "type": "range",
      "id": "height_large_desktop",
      "min": 500,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "label": "Desktop Height - Large Style",
      "default": 750
    },
    {
      "type": "range",
      "id": "height_small_mobile",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Mobile Height - Small Style",
      "default": 300
    },
    {
      "type": "range",
      "id": "height_medium_mobile",
      "min": 250,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Mobile Height - Medium Style",
      "default": 400
    },
    {
      "type": "range",
      "id": "height_large_mobile",
      "min": 300,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Mobile Height - Large Style",
      "default": 500
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Desktop Content Position",
      "options": [
        { "value": "top-left", "label": "Top Left" },
        { "value": "top-center", "label": "Top Center" },
        { "value": "top-right", "label": "Top Right" },
        { "value": "middle-left", "label": "Middle Left" },
        { "value": "middle-center", "label": "Middle Center" },
        { "value": "middle-right", "label": "Middle Right" },
        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "bottom-center", "label": "Bottom Center" },
        { "value": "bottom-right", "label": "Bottom Right" }
      ],
      "default": "middle-center"
    },
    {
      "type": "select",
      "id": "content_position_mobile",
      "label": "Mobile Content Position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Desktop Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Mobile Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Content Max Width",
      "default": 700
    },
    {
      "type": "header",
      "content": "Section Spacing (Padding)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Desktop Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Desktop Padding Bottom",
      "default": 60
    },
    {
      "type": "range",
