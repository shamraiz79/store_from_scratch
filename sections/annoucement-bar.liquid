{%- if section.settings.show_announcement and section.settings.text != blank -%}
  {%- style -%}
    .announcement-bar-wrapper {
      background-color: {{ section.settings.background_color }};
      color: {{ section.settings.text_color }};
      padding: 10px 20px;
      text-align: center;
      font-family: 'Outfit', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      position: relative;
      z-index: 101;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      transition: all 0.3s ease;
    }

    .announcement-bar-link {
      color: inherit;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: opacity 0.2s ease;
    }

    .announcement-bar-link:hover {
      opacity: 0.8;
    }

    .announcement-bar-text {
      margin: 0;
      line-height: 1.2;
    }
  {%- endstyle -%}

  <div class="announcement-bar-wrapper" role="region" aria-label="Announcement">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="announcement-bar-link">
    {%- endif -%}

    <p class="announcement-bar-text">{{ section.settings.text | escape }}</p>

    {%- if section.settings.link != blank -%}
      </a>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Welcome to our store!"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Announcement link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
