{% style %}
  .footer-section-{{ section.id }} {
    --footer-bg: {{ section.settings.bg_color | default: '#0d0d0d' }};
    --footer-text: {{ section.settings.text_color | default: '#e5e5e5' }};
    --footer-text-muted: {{ section.settings.text_muted_color | default: '#999999' }};
    --footer-accent: {{ section.settings.accent_color | default: '#ff4b4b' }};
    --footer-border: {{ section.settings.border_color | default: '#262626' }};

    background-color: var(--footer-bg);
    color: var(--footer-text);
    border-top: 1px solid var(--footer-border);
    position: relative;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .footer-section-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
  }

  .footer__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px 24px;
    box-sizing: border-box;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
    gap: 48px;
    margin-bottom: 50px;
  }

  .footer__block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .footer__block-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 8px 0;
    color: var(--footer-text);
  }

  .footer__logo-link {
    display: inline-block;
    max-width: 100%;
  }

  .footer__logo {
    display: block;
    height: auto;
  }

  .footer__store-name {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--footer-text);
  }

  .footer__description {
    font-size: 14px;
    line-height: 1.6;
    color: var(--footer-text-muted);
    margin: 0;
  }

  .footer__description p {
    margin: 0;
  }

  .footer__menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__menu-link {
    font-size: 14px;
    line-height: 1.4;
    color: var(--footer-text-muted);
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .footer__menu-link:hover {
    color: var(--footer-accent);
    transform: translateX(4px);
  }

  .footer__newsletter-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__newsletter-subtext {
    font-size: 14px;
    line-height: 1.6;
    color: var(--footer-text-muted);
  }

  .footer__newsletter-subtext p {
    margin: 0;
  }

  .footer__newsletter-form {
    width: 100%;
  }

  .footer__newsletter-field {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 2px solid var(--footer-border);
    transition: border-color 0.3s ease;
  }

  .footer__newsletter-field:focus-within {
    border-color: var(--footer-accent);
  }

  .footer__newsletter-input {
    width: 100%;
    background: transparent;
    border: none;
    padding: 10px 0;
    color: var(--footer-text);
    font-size: 14px;
    outline: none;
    font-family: inherit;
  }

  .footer__newsletter-input::placeholder {
    color: var(--footer-text-muted);
    opacity: 0.6;
  }

  .footer__newsletter-button {
    background: transparent;
    border: none;
    color: var(--footer-text);
    cursor: pointer;
    padding: 10px 0 10px 16px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    transition: color 0.25s ease;
    white-space: nowrap;
  }

  .footer__newsletter-button:hover {
    color: var(--footer-accent);
  }

  .footer__newsletter-success {
    color: #10b981;
    font-size: 14px;
    margin: 12px 0 0 0;
    font-weight: 500;
  }

  .footer__newsletter-error {
    color: #ef4444;
    font-size: 13px;
    margin: 12px 0 0 0;
    display: block;
  }

  .footer__bottom {
    border-top: 1px solid var(--footer-border);
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }

  .footer__copyright {
    font-size: 13px;
    color: var(--footer-text-muted);
    margin: 0;
  }

  .footer__social-list {
    display: flex;
    gap: 16px;
    list-style: none;
    padding: 0;
    margin: 0;
    align-items: center;
  }

  .footer__social-link {
    color: var(--footer-text-muted);
    transition: color 0.25s ease, transform 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__social-link:hover {
    color: var(--footer-accent);
    transform: translateY(-2px);
  }

  .footer__social-link svg {
    width: 20px;
    height: 20px;
  }

  .footer__payment-list {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    align-items: center;
  }

  .footer__payment-item svg,
  .footer__payment-item img {
    width: 38px;
    height: 24px;
    object-fit: contain;
  }

  .visually-hidden {
    position: absolute !important;
    overflow: hidden;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    clip: rect(0 0 0 0);
    word-wrap: normal !important;
  }

  @media screen and (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }

  @media screen and (max-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-bottom: 40px;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
      gap: 20px;
    }

    .footer__payment-list,
    .footer__social-list {
      justify-content: center;
    }
  }
{% endstyle %}

<footer class="footer-section-{{ section.id }}">
  <div class="footer__container">
    {%- if section.blocks.size > 0 -%}
      <div class="footer__grid">
        {%- for block in section.blocks -%}
          <div class="footer__block footer__block--{{ block.type }}" {{ block.shopify_attributes }}>
            {%- case block.type -%}
              {%- when 'text' -%}
                <div class="footer__brand-wrapper">
                  <a href="{{ routes.root_url }}" class="footer__logo-link">
                    {%- if block.settings.logo_override != blank -%}
                      {%- assign logo_alt = block.settings.logo_override.alt | default: shop.name | escape -%}
                      {{ block.settings.logo_override | image_url: width: 300 | image_tag: 
                        loading: 'lazy', 
                        class: 'footer__logo', 
                        style: "max-width: 100%;",
                        width: block.settings.logo_width,
                        alt: logo_alt 
                      }}
                    {%- elsif shop.brand.logo != blank -%}
                      {%- assign logo_alt = shop.brand.logo.alt | default: shop.name | escape -%}
                      {{ shop.brand.logo | image_url: width: 300 | image_tag: 
                        loading: 'lazy', 
                        class: 'footer__logo', 
                        style: "max-width: 100%;",
                        width: block.settings.logo_width,
                        alt: logo_alt 
                      }}
                    {%- else -%}
                      <span class="footer__store-name">{{ shop.name }}</span>
                    {%- endif -%}
                  </a>
                  {%- if block.settings.heading != blank -%}
                    <h3 class="footer__block-title" style="margin-top: 15px;">{{ block.settings.heading | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.subtext != blank -%}
                    <div class="footer__description">
                      {{ block.settings.subtext }}
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'link_list' -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="footer__block-title">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                {%- assign menu = linklists[block.settings.menu] -%}
                {%- if menu != blank -%}
                  <ul class="footer__menu-list">
                    {%- for link in menu.links -%}
                      <li>
                        <a href="{{ link.url }}" class="footer__menu-link">
                          {{ link.title }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'newsletter' -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="footer__block-title">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                <div class="footer__newsletter-wrapper">
                  {%- if block.settings.subtext != blank -%}
                    <div class="footer__newsletter-subtext">
                      {{ block.settings.subtext }}
                    </div>
                  {%- endif -%}
                  
                  {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter-form' -%}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="footer__newsletter-field">
                      <input
                        id="NewsletterForm--{{ section.id }}"
                        type="email"
                        name="contact[email]"
                        class="footer__newsletter-input"
                        value="{{ form.email }}"
                        aria-required="true"
                        autocorrect="off"
                        autocapitalize="off"
                        autocomplete="email"
                        placeholder="Your email address"
                        required
                        {% if form.errors %}
                          aria-invalid="true"
                          aria-describedby="ContactFooter-error"
                          autofocus
                        {% elsif form.posted_successfully? %}
                          aria-describedby="ContactFooter-success"
                        {% endif %}
                      >
                      <button type="submit" class="footer__newsletter-button" name="commit" id="Subscribe" aria-label="Subscribe">
                        Subscribe
                      </button>
                    </div>
                    {%- if form.errors -%}
                      <small class="footer__newsletter-error" id="ContactFooter-error">
                        {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
                      </small>
                    {%- endif -%}
                    {%- if form.posted_successfully? -%}
                      <h3 class="footer__newsletter-success" id="ContactFooter-success" tabindex="-1" autofocus>
                        Thanks for subscribing!
                      </h3>
                    {%- endif -%}
                  {%- endform -%}
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="footer__bottom">
      <div class="footer__copyright">
        <p class="footer__copyright-text">
          &copy; {{ 'now' | date: '%Y' }} {% if shop.name != blank %}{{ shop.name }}{% else %}Slashcart{% endif %}. Theme by Shamraiz.
        </p>
      </div>

      {%- if section.settings.show_social_icons -%}
        <div class="footer__socials">
          <ul class="footer__social-list">
            {%- if settings.social_facebook_link != blank -%}
              <li>
                <a href="{{ settings.social_facebook_link }}" class="footer__social-link" target="_blank" rel="noopener">
                  <svg aria-hidden="true" focusable="false" class="icon icon-facebook" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/>
                  </svg>
                  <span class="visually-hidden">Facebook</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_instagram_link != blank -%}
              <li>
                <a href="{{ settings.social_instagram_link }}" class="footer__social-link" target="_blank" rel="noopener">
                  <svg aria-hidden="true" focusable="false" class="icon icon-instagram" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                  <span class="visually-hidden">Instagram</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank or settings.social_x_link != blank -%}
              <li>
                <a href="{{ settings.social_x_link | default: settings.social_twitter_link }}" class="footer__social-link" target="_blank" rel="noopener">
                  <svg aria-hidden="true" focusable="false" class="icon icon-twitter" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                  <span class="visually-hidden">X / Twitter</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <li>
                <a href="{{ settings.social_pinterest_link }}" class="footer__social-link" target="_blank" rel="noopener">
                  <svg aria-hidden="true" focusable="false" class="icon icon-pinterest" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.966 1.406-5.966s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.204 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.27 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.621 0 11.988-5.367 11.988-11.987C24 5.368 18.633 0 12.017 0z"/>
                  </svg>
                  <span class="visually-hidden">Pinterest</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <li>
                <a href="{{ settings.social_youtube_link }}" class="footer__social-link" target="_blank" rel="noopener">
                  <svg aria-hidden="true" focusable="false" class="icon icon-youtube" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M23.498 6.163a3.003 3.003 0 00-2.11-2.11C19.517 3.545 12 3.545 12 3.545s-7.517 0-9.388.508a3.003 3.003 0 00-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 002.11 2.11c1.871.508 9.388.508 9.388.508s7.517 0 9.388-.508a3.002 3.002 0 002.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                  <span class="visually-hidden">YouTube</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li>
                <a href="{{ settings.social_tiktok_link }}" class="footer__social-link" target="_blank" rel="noopener">
                  <svg aria-hidden="true" focusable="false" class="icon icon-tiktok" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.02 1.59 4.18.94 1.13 2.26 1.88 3.71 2.08v3.83c-1.39-.02-2.77-.41-3.94-1.18-.54-.36-1.03-.8-1.43-1.31v7.62c.03 2.13-.71 4.22-2.1 5.83-1.52 1.76-3.8 2.76-6.12 2.76-2.07-.01-4.09-.81-5.6-2.24C1.04 20.08-.02 18.01 0 15.86c-.08-2.61 1.25-5.09 3.52-6.38 1.95-1.11 4.31-1.39 6.48-.75v3.94c-1.35-.5-2.86-.33-4.07.47-1.11.74-1.78 1.99-1.77 3.32-.01 1.09.43 2.14 1.21 2.9.8.77 1.89 1.19 3 1.17 1.25.01 2.45-.52 3.24-1.49.88-1.07 1.33-2.44 1.28-3.81L12.92.02c-.13 0-.27 0-.4-.01z"/>
                  </svg>
                  <span class="visually-hidden">TikTok</span>
                </a>
              </li>
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment">
          <span class="visually-hidden">Payment methods</span>
          <ul class="footer__payment-list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="footer__payment-item">
                {{ type | payment_type_svg_tag: class: 'payment-icon' }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0b0b0c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#f4f4f5"
    },
    {
      "type": "color",
      "id": "text_muted_color",
      "label": "Muted Text Color",
      "default": "#a1a1aa"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / Hover Color",
      "default": "#3b82f6"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#27272a"
    },
    {
      "type": "header",
      "content": "Sub-footer Settings"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show social media icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 40
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "text",
      "name": "Brand Details",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_override",
          "label": "Custom Footer Logo",
          "info": "Overrides the global Brand Settings logo."
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 250,
          "step": 10,
          "unit": "px",
          "label": "Logo Width",
          "default": 120
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Brand Name / Heading",
          "default": "Slashcart"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Description",
          "default": "<p>A premium shopping experience built on quality, style, and exceptional service.</p>"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Navigation Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Menu Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter Signup",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Newsletter Heading",
          "default": "Subscribe"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Subtext",
          "default": "<p>Join our newsletter to receive updates on new arrivals, special promotions, and insider-only discounts.</p>"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "text"
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Quick Links",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Customer Service",
          "menu": "footer"
        }
      },
      {
        "type": "newsletter"
      }
    ]
  }
}
{% endschema %}
