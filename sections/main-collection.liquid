<style>
  .collection-page-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 60px 24px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #18181b;
  }

  .collection-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .collection-title {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 16px 0;
  }

  .collection-description {
    max-width: 600px;
    margin: 0 auto;
    font-size: 16px;
    line-height: 1.6;
    color: #71717a;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 30px;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .product-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .product-card__image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: #f4f4f5;
    border-radius: 12px;
    margin-bottom: 16px;
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .product-card__image {
    transform: scale(1.05);
  }

  .product-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: #e4e4e7;
    display: block;
  }

  /* Badges */
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    z-index: 2;
  }

  .badge--sale {
    background-color: #ef4444;
    color: #ffffff;
  }

  .badge--sold-out {
    background-color: #27272a;
    color: #ffffff;
  }

  /* Info */
  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .product-card__title {
    font-size: 16px;
    font-weight: 500;
    margin: 0;
    line-height: 1.4;
    color: #18181b;
    transition: color 0.2s ease;
  }

  .product-card:hover .product-card__title {
    color: #2563eb;
  }

  .product-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
  }

  .price-item--regular {
    color: #71717a;
    text-decoration: line-through;
    font-weight: 400;
    font-size: 14px;
  }

  .price-item--sale {
    color: #ef4444;
  }

  /* Empty state */
  .collection-empty {
    text-align: center;
    padding: 80px 24px;
    border: 1px dashed #e4e4e7;
    border-radius: 12px;
  }

  .collection-empty p {
    font-size: 16px;
    color: #71717a;
    margin: 0 0 20px 0;
  }

  .btn {
    display: inline-block;
    background: #18181b;
    color: #ffffff;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 8px;
    transition: background-color 0.2s ease;
  }

  .btn:hover {
    background: #27272a;
  }

  /* Pagination */
  .pagination {
    margin-top: 60px;
    display: flex;
    justify-content: center;
  }

  .pagination__list {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pagination a,
  .pagination span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 6px;
    font-size: 14px;
    text-decoration: none;
    color: #71717a;
    border: 1px solid #e4e4e7;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .pagination a:hover {
    color: #18181b;
    border-color: #a1a1aa;
    background-color: #f4f4f5;
  }

  .pagination .current {
    background: #18181b;
    color: #ffffff;
    border-color: #18181b;
  }

  /* Responsive Design */
  @media screen and (max-width: 990px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px 20px;
    }
    .collection-page-container {
      padding: 40px 20px;
    }
  }

  @media screen and (max-width: 576px) {
    .collection-title {
      font-size: 28px;
    }
    .product-card__image-wrapper {
      border-radius: 8px;
      margin-bottom: 12px;
    }
    .product-card__title {
      font-size: 14px;
    }
    .product-card__price {
      font-size: 14px;
    }
  }
</style>

{% paginate collection.products by 12 %}
  <div class="collection-page-container">
    <header class="collection-header">
      <h1 class="collection-title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection-description">
          {{ collection.description }}
        </div>
      {%- endif -%}
    </header>

    <div class="collection-products">
      {%- if collection.products.size > 0 -%}
        <div class="product-grid">
          {%- for product in collection.products -%}
            <div class="product-card">
              <a href="{{ product.url | within: collection }}" class="product-card__link">
                <div class="product-card__image-wrapper">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 600 | image_tag: 
                      loading: 'lazy', 
                      class: 'product-card__image', 
                      alt: product.featured_image.alt | default: product.title 
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder' }}
                  {%- endif -%}
                  
                  {%- unless product.available -%}
                    <span class="badge badge--sold-out">Sold Out</span>
                  {%- else -%}
                    {%- if product.compare_at_price > product.price -%}
                      <span class="badge badge--sale">Sale</span>
                    {%- endif -%}
                  {%- endunless -%}
                </div>
                
                <div class="product-card__info">
                  <h2 class="product-card__title">{{ product.title }}</h2>
                  <div class="product-card__price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="price-item price-item--regular">
                        {{ product.compare_at_price | money }}
                      </span>
                      <span class="price-item price-item--sale">
                        {{ product.price | money }}
                      </span>
                    {%- else -%}
                      <span class="price-item">
                        {{ product.price | money }}
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </div>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            <nav role="navigation">
              <ul class="pagination__list">
                {%- if paginate.previous-%}
                  <li>
                    <a href="{{ paginate.previous.url }}" aria-label="Previous page">
                      &laquo;
                    </a>
                  </li>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <li>
                      <a href="{{ part.url }}" aria-label="Page {{ part.title }}">
                        {{ part.title }}
                      </a>
                    </li>
                  {%- else -%}
                    {%- if part.title == paginate.current_page -%}
                      <li>
                        <span class="current" aria-current="page">{{ part.title }}</span>
                      </li>
                    {%- else -%}
                      <li>
                        <span>{{ part.title }}</span>
                      </li>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <li>
                    <a href="{{ paginate.next.url }}" aria-label="Next page">
                      &raquo;
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            </nav>
          </div>
        {%- endif -%}

      {%- else -%}
        <div class="collection-empty">
          <p>No products found in this collection.</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn">Shop All Products</a>
        </div>
      {%- endif -%}
    </div>
  </div>
{% endpaginate %}
