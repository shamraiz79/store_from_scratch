{% style %}
  /* Scoped CSS for the Premium Product Section */
  .premium-product-container {
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
    gap: 48px; /* Increased gap for clean breathing room */
    font-family: inherit;
    color: #333;
  }

  /* Desktop Layout: Side-by-Side */
  @media (min-width: 768px) {
    .premium-product-container {
      flex-direction: row;
      align-items: flex-start;
      /* Generous padding on larger screens */
    }
  }

  /* Left Side: Controlled Image Sizing */
  .premium-product-image-wrapper {
    flex: 1;
    width: 100%;
    max-width: 600px; /* Prevents the image from becoming too massive */
    border-radius: 8px;
    overflow: hidden;
    background-color: #f8f8f8;
    
    /* Forces a consistent 1:1 square aspect ratio for all product images */
    aspect-ratio: 1 / 1; 
    position: relative;
  }

  .premium-product-image-wrapper img, 
  .premium-product-image-wrapper svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    
  }

  /* Right Side: Details & Description */
  .premium-product-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
    
    /* Makes the details sticky so they follow the user scrolling down a long image */
    position: sticky;
    top: 40px; 
  }

  .premium-product-title {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
    color: #111;
  }

  .premium-product-price {
    font-size: 1.5rem;
    font-weight: 500;
    color: #555;
    border-bottom: 1px solid #eaeaea;
    padding-bottom: 20px;
  }

  /* Product Description Styling */
  .premium-product-description {
    font-size: 1rem;
    line-height: 1.6; /* Higher line-height for easier reading */
    color: #444;
    margin-bottom: 12px;
  }

  /* Button Styling */
  .premium-add-to-cart {
    background-color: #111;
    color: #fff;
    border: none;
    padding: 18px 32px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border-radius: 4px; /* Slightly sharper corners for a modern edge */
    cursor: pointer;
    transition: background-color 0.2s ease;
    width: 100%;
    max-width: 400px;
  }

  .premium-add-to-cart:hover {
    background-color: #333;
  }

  .premium-add-to-cart:disabled {
    background-color: #d8d8d8;
    color: #888;
    cursor: not-allowed;
  }
{% endstyle %}

<div class="premium-product-container">
  
  <div class="premium-product-image-wrapper">
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 1000 | image_tag: alt: product.title, loading: 'lazy' }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
  </div>

  <div class="premium-product-details">
    
    <h1 class="premium-product-title">{{ product.title }}</h1>
    
    <div class="premium-product-price">
      {{ product.price | money }}
    </div>

    {% if product.description != blank %}
      <div class="premium-product-description">
        {{ product.description }}
      </div>
    {% endif %}

    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      
      <button 
        type="submit" 
        name="add" 
        class="premium-add-to-cart" 
        {% unless product.available %}disabled{% endunless %}
      >
        {% if product.available %}
          Add to Cart
        {% else %}
          Sold Out
        {% endif %}
      </button>
    {% endform %}
    
  </div>
</div>

{% schema %}
{
  "name": "Main Products",
  "tag": "section",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Main Products"
    }
  ]
}
{% endschema %}